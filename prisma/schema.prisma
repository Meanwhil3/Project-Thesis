generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LessonStatus {
  OPEN   @map("SHOW")
  CLOSED @map("HIDE")
}

enum CourseStatus {
  OPEN   @map("SHOW")
  CLOSED @map("HIDE")
}

enum ExamType {
  FILL_IN_THE_BLANK @map("FILL IN THE BLANK")
  MULTIPLE_CHOICE   @map("MULTIPLE CHOICE")
}

enum ExamStatus {
  HIDE
  SHOW
}

enum AttemptStatus {
  IN_PROGRESS @map("IN PROGRESS")
  COMPLETED
}

enum WoodStatus {
  HIDE
  SHOW
}


// --- Models ---

model Role {
  role_id BigInt @id @default(autoincrement())
  name    String @unique @db.VarChar(100)
  users   User[]

  @@map("Role")
}

model User {
  user_id    BigInt    @id @default(autoincrement())
  role_id    BigInt?
  first_name String    @db.VarChar(120)
  last_name  String    @db.VarChar(120)
  email      String    @unique @db.VarChar(255)
  password   String    @db.Text
  is_active  Boolean?  @default(false)
  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  role Role? @relation(fields: [role_id], references: [role_id])

  // Relations
  enrollments   CourseEnrollments[]
  instructing   Instructor[]
  announcements Announcements[]
  lessons       Lessons[]
  exams         Exams[]
  exam_attempts Exam_Attempts[]
  woods_created Wood[]

  @@map("User")
}

model Course {
  course_id          BigInt        @id @default(autoincrement())
  course_name        String        @db.VarChar(255)
  enroll_code        String?       @db.VarChar(255)
  course_description String?       @db.Text
  image_url          String?       @db.Text
  location           String?       @db.Text
  course_status      CourseStatus?
  start_date         DateTime?     @db.Timestamptz
  end_date           DateTime?     @db.Timestamptz
  created_at         DateTime?     @db.Timestamptz
  deleted_at         DateTime?     @db.Timestamptz

  enrollments   CourseEnrollments[]
  instructors   Instructor[]
  announcements Announcements[]
  lessons       Lessons[]
  exams         Exams[]

  @@map("Course")
}

model CourseEnrollments {
  enrollment_id   BigInt    @id @default(autoincrement())
  user_id         BigInt
  course_id       BigInt
  enrollment_date DateTime  @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  user   User?   @relation(fields: [user_id], references: [user_id])
  course Course? @relation(fields: [course_id], references: [course_id])

  @@index([course_id])
  @@index([user_id])
  @@index([user_id, course_id])
  @@map("Course_Enrollments")
}

model Instructor {
  user_id   BigInt
  course_id BigInt

  user   User   @relation(fields: [user_id], references: [user_id])
  course Course @relation(fields: [course_id], references: [course_id])

  @@id([user_id, course_id])
  @@index([course_id])
  @@map("Instructor")
}

model Announcements {
  announcement_id BigInt    @id @default(autoincrement())
  course_id       BigInt
  title           String    @db.Text
  content         String    @db.Text
  created_at      DateTime  @default(now()) @db.Timestamptz
  created_by      BigInt?
  deleted_at      DateTime? @db.Timestamptz

  course Course @relation(fields: [course_id], references: [course_id], onDelete: Restrict)
  author User?  @relation(fields: [created_by], references: [user_id], onDelete: SetNull)

  @@index([course_id])
  @@map("Announcements")
}

model Lessons {
  lesson_id      BigInt        @id @default(autoincrement())
  course_id      BigInt?       
  lesson_title   String        @db.Text
  lesson_content String        @db.Text
  lesson_status  LessonStatus?
  order_index    Int           @default(0) // สำหรับสลับลำดับบทเรียน
  created_at     DateTime      @default(now()) @db.Timestamptz
  created_by     BigInt?
  deleted_at     DateTime?     @db.Timestamptz

  course      Course?             @relation(fields: [course_id], references: [course_id], onDelete: Restrict)
  author      User?               @relation(fields: [created_by], references: [user_id], onDelete: SetNull)
  attachments Lesson_Attachments[]

  @@index([course_id, order_index])
  @@map("Lessons")
}

model Lesson_Attachments {
  attachment_id BigInt   @id @default(autoincrement())
  lesson_id     BigInt
  display_name  String   @db.VarChar(255)
  file_path     String   @db.Text
  file_type     String   @db.Text
  created_at    DateTime @default(now()) @db.Timestamptz

  lesson Lessons @relation(fields: [lesson_id], references: [lesson_id], onDelete: Restrict)

  @@index([lesson_id])
  @@map("Lesson_Attachments")
}

model Exams {
  exam_id          BigInt      @id @default(autoincrement())
  course_id        BigInt?
  exam_title       String      @db.Text
  exam_description String?     @db.Text
  exam_type        ExamType?
  duration_minute  Int
  exam_status      ExamStatus?
  examAccessCode   String?     @map("exam_access_code") @db.VarChar(6)
  created_at       DateTime    @default(now()) @db.Timestamptz
  created_by       BigInt?
  deleted_at       DateTime?   @db.Timestamptz
  open_at          DateTime?   @db.Timestamptz
  close_at         DateTime?   @db.Timestamptz

  course    Course?         @relation(fields: [course_id], references: [course_id])
  author    User?           @relation(fields: [created_by], references: [user_id])
  questions Questions[]
  attempts  Exam_Attempts[]

  @@unique([course_id, examAccessCode], map: "Exams_course_id_exam_access_code_key")
  @@index([open_at])
  @@index([close_at])
  @@map("Exams")
}

model Questions {
  question_id     BigInt    @id @default(autoincrement())
  exam_id         BigInt
  score           Int
  question_detail String    @db.Text
  created_at      DateTime? @default(now())
  deleted_at      DateTime? @db.Timestamptz

  exam    Exams?    @relation(fields: [exam_id], references: [exam_id])
  choices Choices[]

  @@index([exam_id])
  @@map("Questions")
}

model Choices {
  choice_id     BigInt    @id @default(autoincrement())
  question_id   BigInt
  choice_detail String    @db.Text
  is_correct    Boolean   @default(false)
  created_at    DateTime? @default(now())
  deleted_at    DateTime? @db.Timestamptz

  question Questions? @relation(fields: [question_id], references: [question_id])

  @@index([question_id])
  @@map("Choices")
}

model Exam_Attempts {
  attempt_id      BigInt        @id @default(autoincrement())
  user_id         BigInt
  exam_id         BigInt
  attempt_status  AttemptStatus @default(IN_PROGRESS)
  total_score     Int           @default(0)
  started_at      DateTime      @default(now()) @db.Timestamptz
  submit_datetime DateTime?     @db.Timestamptz
  created_at      DateTime      @default(now()) @db.Timestamptz
  deleted_at      DateTime?     @db.Timestamptz

  user User  @relation(fields: [user_id], references: [user_id])
  exam Exams @relation(fields: [exam_id], references: [exam_id])

  @@index([exam_id, user_id])
  @@index([submit_datetime])
  @@map("Exam_Attempts")
}

model Wood {
  wood_id                      BigInt      @id @default(autoincrement())
  scientific_name              String?     @db.VarChar(255)
  common_name                  String?     @db.VarChar(255)
  wood_origin                  String?     @db.VarChar(255)
  wood_description             String?     @db.Text
  wood_status                  WoodStatus?
  wood_taste                   String?     @db.VarChar(255)
  wood_odor                    String?     @db.VarChar(255)
  wood_texture                 String?     @db.VarChar(255) // ปรับเป็นพิมพ์เล็กตามมาตรฐาน
  wood_luster                  String?     @db.VarChar(255)
  wood_grain                   String?     @db.VarChar(255)
  wood_weight                  String?     @db.VarChar(255)
  wood_colors                  String?     @db.VarChar(255)
  sapwood_heartwood_color_diff String?     @db.VarChar(255)
  growth_rings                 String?     @db.VarChar(255)
  included_phloem              String?     @db.VarChar(255)
  intercellular_canals         String?     @db.VarChar(255)
  vp_porosity                  String?     @db.VarChar(255)
  vp_vessel_grouping           String?     @db.VarChar(255)
  vp_vessel_arrangement        String?     @db.VarChar(255)
  vp_inclusions_in_Pores       String?     @db.VarChar(255)
  vp_Pores_frequency           String?     @db.VarChar(255)
  vp_Pores_size                String?     @db.VarChar(255)
  vp_Pores_rays_ratio          String?     @db.VarChar(255)
  rays_per_mm                  String?     @db.VarChar(255)
  rays_width                   String?     @db.VarChar(255)
  rays_two_distinct_sizes      String?     @db.VarChar(255)
  rays_aggregate               String?     @db.VarChar(255)
  rays_storied_ripple_mark     String?     @db.VarChar(255)
  rays_deposit_in_rays         String?     @db.VarChar(255)
  ap_type                      String?     @db.VarChar(255)
  ap_paratracheal              String?     @db.VarChar(255)
  ap_apotracheal               String?     @db.VarChar(255)
  ap_banded                    String?     @db.VarChar(255)
  created_by                   BigInt?
  deleted_at                   DateTime?   @db.Timestamptz
  created_at                   DateTime?   @default(now()) @db.Timestamptz
  updated_at                   DateTime?   @updatedAt @db.Timestamptz

  author User?         @relation(fields: [created_by], references: [user_id], onDelete: SetNull)
  images Wood_Images[]

  @@map("Wood")
}

model Wood_Images {
  image_id          BigInt   @id @default(autoincrement())
  wood_id           BigInt?
  image_url         String   @unique @db.Text
  image_description String?  @db.Text
  date_added        DateTime @default(now()) @db.Timestamptz

  wood Wood? @relation(fields: [wood_id], references: [wood_id], onDelete: Cascade)

  @@map("Wood_Images")
}
